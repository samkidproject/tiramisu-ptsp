rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Settings collection
    match /settings/{settingsId} {
      allow read: if true; // All visitors can view agency profile
      allow create: if settingsId == 'instansi' || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow get: if request.auth != null;
      allow list: if isAdminOrPetugas();
      allow create: if request.auth != null && request.auth.uid == userId && (
        request.resource.data.role == 'user' ||
        ('email' in request.auth.token && (
          (request.resource.data.role == 'admin' && (request.auth.token.email.lower() == 'samkidproject@gmail.com' || request.auth.token.email.lower() == 'lukepoktlampung@gmail.com')) ||
          (request.resource.data.role == 'petugas' && exists(/databases/$(database)/documents/allowedOfficers/$(request.auth.token.email.lower())))
        ))
      );
      allow update: if request.auth != null && (
        ('email' in request.auth.token && (request.auth.token.email.lower() == 'samkidproject@gmail.com' || request.auth.token.email.lower() == 'lukepoktlampung@gmail.com')) ||
        (request.auth.uid == userId && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
          ('email' in request.auth.token && (
            (request.resource.data.role == 'petugas' && exists(/databases/$(database)/documents/allowedOfficers/$(request.auth.token.email.lower()))) ||
            (request.resource.data.role == 'admin' && (request.auth.token.email.lower() == 'samkidproject@gmail.com' || request.auth.token.email.lower() == 'lukepoktlampung@gmail.com'))
          ))
        ))
      );
      allow delete: if request.auth != null && 'email' in request.auth.token && (
        request.auth.token.email.lower() == 'samkidproject@gmail.com' ||
        request.auth.token.email.lower() == 'lukepoktlampung@gmail.com'
      );
    }

    // Receipts collection
    match /receipts/{receiptId} {
      allow get: if true; // QR direct verification
      allow list: if request.auth != null && (
        isAdminOrPetugas() || 
        resource.data.pengirimUid == request.auth.uid
      );
      allow create: if request.auth != null; // Both user and officers can log receipts
      allow update: if isAdminOrPetugas();
      allow delete: if request.auth != null && 'email' in request.auth.token && (
        request.auth.token.email.lower() == 'samkidproject@gmail.com' ||
        request.auth.token.email.lower() == 'lukepoktlampung@gmail.com'
      );
    }

    // Allowed officers collection
    match /allowedOfficers/{email} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null && 'email' in request.auth.token && (
        request.auth.token.email.lower() == 'samkidproject@gmail.com' ||
        request.auth.token.email.lower() == 'lukepoktlampung@gmail.com'
      );
    }

    // Audit logs collection
    match /auditLogs/{logId} {
      allow read: if isAdminOrPetugas();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Reusable helpers
    function getRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && (
        ('email' in request.auth.token && request.auth.token.email.lower() == 'lukepoktlampung@gmail.com') || 
        ('email' in request.auth.token && request.auth.token.email.lower() == 'samkidproject@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole(request.auth.uid) == 'admin')
      );
    }

    function isPetugas() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (getRole(request.auth.uid) == 'petugas' || getRole(request.auth.uid) == 'admin')
      );
    }

    function isAdminOrPetugas() {
      return isAdmin() || isPetugas();
    }
  }
}
